# global_brief — environment variables

# Required
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

SAVE_MARKDOWN=true

# Optional: when SAVE_MARKDOWN=true, specify the directory to save the markdown files. If not set, it defaults to the current directory.
# BRIEF_OUTPUT_DIR=/Users/your_username/brief_outputs
